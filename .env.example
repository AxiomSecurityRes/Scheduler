# ============================================================================
#  환경 변수 예시 파일 (.env.example)
#  실제 배포 시 이 파일을 복사하여 ".env" 로 만들고 값을 채워 넣으세요.
#  Render 에서는 Dashboard > Environment 에 동일한 키로 등록합니다.
#  주의: .env 파일은 절대 git 에 커밋하지 마세요 (.gitignore 에 포함됨).
# ============================================================================

# ---------- Supabase (백엔드에서 사용) ----------
# Supabase 프로젝트 > Settings > API 에서 확인
SUPABASE_URL=https://your-project-ref.supabase.co
# service_role 키 (서버 전용, 절대 프론트엔드에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# JWT 검증용 시크릿 (Settings > API > JWT Secret)
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ---------- Web Push (VAPID) ----------
# 아래 명령으로 키를 생성하세요:
#   python -m backend.generate_vapid_keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@example.com

# ---------- 앱 설정 ----------
# 프론트엔드가 호출을 허용할 오리진 (콤마로 구분). 빈 값이면 전체 허용(*)
ALLOWED_ORIGINS=
# 마감 임박 알림 기준 (일). 콤마 구분. 예: 1,3,7
DEADLINE_REMINDER_DAYS=1,3,7
# 백그라운드 스케줄러 활성화 (Render Cron 을 쓰면 false 로 두세요)
ENABLE_SCHEDULER=true
# 서버 포트 (Render 가 자동 주입)
PORT=8000

# ============================================================================
#  프론트엔드 공개 설정 (frontend/js/config.js 에 입력 — 공개되어도 안전한 값)
#  - SUPABASE_URL          : 위와 동일
#  - SUPABASE_ANON_KEY     : Settings > API > anon public 키
#  - VAPID_PUBLIC_KEY      : 위와 동일
# ============================================================================
